# App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL + PostGIS)
# Prefer DATABASE_URL in hosted environments such as Coolify.
# DATABASE_URL=postgresql://vts:vts@postgres:5432/vts
DB_HOST=localhost
DB_PORT=5432
DB_USER=vts
DB_PASSWORD=vts
DB_NAME=vts
DB_SYNCHRONIZE=true
# Run committed TypeORM migrations automatically on application startup.
DB_MIGRATIONS_RUN=true
DB_SSL=false

# Redis
# Prefer REDIS_URL in hosted environments such as Coolify.
# REDIS_URL=redis://redis:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_TTL=30d

# OTP / SMS
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
# Provider: console (dev) | africastalking | twilio
SMS_PROVIDER=console

# Email OTP. "smtp" uses standard SMTP and works with a self-hosted mail
# server; "console" logs the OTP in the backend logs for development.
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=VTS Mali <no-reply@example.com>

# Optional comma-separated admin identities.
ADMIN_PHONES=
ADMIN_EMAILS=

# Push notifications
# Provider: console (dev, logs only) | fcm (real Firebase Cloud Messaging)
PUSH_PROVIDER=console
# Path to a Firebase service-account JSON. Required when PUSH_PROVIDER=fcm.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json

# Merchant public branding images. Mount /app/uploads as persistent storage in
# Coolify so logos and KYC files survive container redeployments.
MERCHANT_LOGO_DIR=uploads/merchant-logos
