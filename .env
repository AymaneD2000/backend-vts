# App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL + PostGIS)
DB_HOST=localhost
DB_PORT=5432
DB_USER=vts
DB_PASSWORD=vts
DB_NAME=vts
DB_SYNCHRONIZE=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_TTL=30d

# OTP / SMS
OTP_TTL_SECONDS=300
OTP_LENGTH=6
# Provider: console (dev) | africastalking | twilio
SMS_PROVIDER=console

# Admin: comma-separated phones granted the admin role on login
ADMIN_PHONES=+22300000000
